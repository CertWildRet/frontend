# ── CWR frontend env ──────────────────────────────────────────────────────
# Copy to `.env.local` for local dev; set the same vars in Vercel for prod.

# On-chain program id (V6). Matches the CLDmHatW mainnet deployment.
NEXT_PUBLIC_PROGRAM_ID=BLi7NKqekZGh5zWNwmUK2bzs2tAR3sPC7A1VrgQdEaYL

# RPC the BROWSER uses for reads + sending deposit/withdraw txs.
# Leave UNSET to route through the built-in /api/rpc proxy (recommended —
# keeps your paid RPC key server-side, off the client). Set it only if you
# want the browser to hit a public/keyless RPC directly.
# NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# SERVER-SIDE RPC for the /api/rpc proxy (NOT exposed to the browser). Put the
# paid endpoint (with key) here. Required when NEXT_PUBLIC_RPC_URL is unset.
RPC_URL=https://oretech-mainnet-90d6.mainnet.rpcpool.com/<YOUR-KEY>

# Live crank-stats feed — the brain's SSE endpoint (one chain subscription
# fanned out to all visitors). e.g. https://crank-simple.onrender.com
NEXT_PUBLIC_BRAIN_URL=https://crank-simple.onrender.com

# ZINC live crank feed — the SAME keeper codebase deployed with protocol=zinc.
# Drives the /zinc Live crank panel (uses its lastCrank: the dZINC full-coverage
# deploy). e.g. https://crank-simple-zinc.onrender.com
NEXT_PUBLIC_ZINC_BRAIN_URL=https://crank-simple-zinc.onrender.com

# Off-chain referral service base URL (CertWildRet/referral-service on Render).
NEXT_PUBLIC_REFERRAL_URL=https://cwr-referral.onrender.com

#FORCE COMMIT
# Off-chain analytics service base URL (CertWildRet/analytics on Render). Powers the
# Position tab mining history and /stats Ore Data. The browser calls this directly,
# so the analytics service must allow this site's origin via CORS.
NEXT_PUBLIC_ANALYTICS_URL=https://analytics-mwav.onrender.com
